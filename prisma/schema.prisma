generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  perfil    String
  ra        String?  @unique
  
  logs      AttendanceLog[]
  turmas    Turma[]  @relation("Matriculas") // Turmas que ele estuda
  turmasLecionadas Turma[] @relation("Professor") // NOVO: Turmas que ele ensina
}

model Turma {
  id            String     @id @default(uuid())
  nome          String
  latitude      Float
  longitude     Float
  raioMetros    Int        @default(20)
  totalAulas    Int        @default(20)
  
  // NOVOS CAMPOS PARA CONTROLE DE TEMPO
  diaSemana     Int        // 0 = Domingo, 1 = Segunda, ..., 6 = Sábado
  horarioInicio String     // Formato "HH:mm" (ex: "19:00")
  
  logs          AttendanceLog[]
  alunos        User[]     @relation("Matriculas")
  
  professorId   String?    
  professor     User?      @relation("Professor", fields: [professorId], references: [id])
}

// O model AttendanceLog continua igual, não precisa mexer.
model AttendanceLog {
  id          String   @id @default(uuid())
  dataHora    DateTime @default(now())
  latitude    Float
  longitude   Float
  statusSiga  String   @default("PENDENTE")
  dataExclusao DateTime
  
  // NOVO CAMPO DE SEGURANÇA
  deviceId    String?  
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  turmaId     String
  turma       Turma    @relation(fields: [turmaId], references: [id])
}